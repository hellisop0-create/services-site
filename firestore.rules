rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['client', 'worker', 'admin'];
    }

    // User Collection Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Worker Collection Rules
    match /workers/{workerId} {
      // Everyone can see approved workers
      allow read: if true; 
      
      allow create: if isSignedIn() && isOwner(workerId) && 
                      get(/databases/$(database)/documents/users/$(workerId)).data.role == 'worker';
      
      allow update: if (isOwner(workerId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'profileImage', 'phoneNumber', 'city', 'area', 'category', 'experience', 'bio'
        ])
      )) || isAdmin();
      
      allow delete: if isAdmin();
    }

    // Admins helper collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
